# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3007
NODE_ENV=production

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_secret_string

# ─── Default Admin ────────────────────────────────────────────────────────────
DEFAULT_ADMIN_ACCOUNT=ADMIN
DEFAULT_ADMIN_PASSWORD=change_me_on_first_login

# ─── Database ─────────────────────────────────────────────────────────────────
# Docker: use /app/data/system.db (volume mounted)
# Local dev: leave blank to use server/system.db
DB_PATH=/app/data/system.db

# ─── File Storage ─────────────────────────────────────────────────────────────
# Docker: /app/uploads (volume mounted)
# Local dev: ./uploads
UPLOAD_DIR=/app/uploads

# ─── Gemini AI ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# Initial default model strings (can be changed in admin → LLM 模型設定)
GEMINI_MODEL_PRO=gemini-3-pro-preview
GEMINI_MODEL_FLASH=gemini-3-flash-preview

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
ADMIN_NOTIFY_EMAIL=admin@your-domain.com
SMTP_SERVER=smtp.your-domain.com
SMTP_PORT=25
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
FROM_ADDRESS=noreply@your-domain.com

# ─── LDAP (optional, remove if not using AD login) ────────────────────────────
# LDAP_URL=ldap://your-ldap-server:389
# LDAP_BASE_DN=DC=yourdomain,DC=local
# LDAP_MANAGER_DN=CN=manager,DC=yourdomain,DC=local
# LDAP_MANAGER_PASSWORD=your_ldap_manager_password

# ─── MCP User Identity (RS256 JWT) ────────────────────────────────────────────
# 產生 key pair（首次部署執行一次）：
#   cd server/certs
#   openssl genrsa -out mcp-jwt-private.pem 2048
#   openssl rsa -in mcp-jwt-private.pem -pubout -out foxlink-gpt-public.pem
# 詳細說明見 server/certs/README.md 及 docs/mcp-user-identity-auth.md
MCP_JWT_PRIVATE_KEY_PATH=./certs/mcp-jwt-private.pem
MCP_JWT_PUBLIC_KEY_PATH=./certs/foxlink-gpt-public.pem
